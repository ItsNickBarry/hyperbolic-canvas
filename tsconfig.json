{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "resolveJsonModule": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": ".tsbuildinfo",
    "strict": false,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src"]
}
