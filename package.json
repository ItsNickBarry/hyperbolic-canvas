{
  "name": "hyperbolic-canvas",
  "version": "1.0.1",
  "description": "The Poincaré disk model of the hyperbolic plane on the HTML canvas.",
  "keywords": [
    "hyperbolic",
    "geometry",
    "canvas",
    "wow",
    "visualization",
    "non-euclidean",
    "poincare",
    "math",
    "maths"
  ],
  "homepage": "https://github.com/itsnickbarry/hyperbolic-canvas#readme",
  "bugs": {
    "url": "https://github.com/itsnickbarry/hyperbolic-canvas/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsnickbarry/hyperbolic-canvas.git"
  },
  "license": "MIT",
  "author": "Nick Barry",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "main": "src/index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "pnpm clean && tsc --build",
    "clean": "rm -rf dist/",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "test": "pnpm typecheck && tsx --test --experimental-test-coverage",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.test.json"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.5.0",
    "@types/seedrandom": "^3.0.8",
    "canvas": "^3.2.1",
    "exec-staged": "^0.2.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "seedrandom": "^3.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
